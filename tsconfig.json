{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "commonjs",
    "target": "esnext",

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "jsx": "react-jsx",

    "isolatedModules": true,
    "skipLibCheck": true,

    "allowJs": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}